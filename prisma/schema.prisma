generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Certificate {
  id           String   @id @default(uuid())
  recipient    String
  issuer       String   @default("Platforma")
  issueDate    DateTime @default(now())
  templateUrl  String?  @db.Text
  elementsData String   @db.Text
  qrCodeUrl    String?
  isTemplate   Boolean  @default(false)
  createdAt    DateTime @default(now())
}
